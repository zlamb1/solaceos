make qemu -j8

if [[ $1 == 'debug' ]]; then
        qemu-system-x86_64 -drive format=raw,media=disk,file=qmu.img \
                           -nic none -m 4G -s -S &
        gdb -x gdb/gdb-cmd
else
        qemu-system-x86_64 -drive format=raw,media=disk,file=qmu.img \
                           -nic none -m 4G
fi